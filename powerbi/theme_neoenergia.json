{
  "name": "Neoenergia Coelba",
  "dataColors": [
    "#003F7D",
    "#00A651",
    "#34B233",
    "#00B5E2",
    "#F4C542",
    "#F28C28",
    "#D94F4F",
    "#7A8AA0"
  ],
  "background": "#F5F8FB",
  "foreground": "#1F2D3D",
  "tableAccent": "#003F7D",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#1F2D3D" } },
            "fontSize": 13,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#D9E2EC" } },
            "radius": 8
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#334E68" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F5F8FB" } },
            "transparency": 0
          }
        ],
        "wallpaper": [
          {
            "color": { "solid": { "color": "#F5F8FB" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#003F7D" } },
            "fontSize": 24,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#486581" } },
            "fontSize": 11
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ]
      }
    }
  }
}

